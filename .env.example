# HappyNest — Blanc Belle: Environment Variables
# Copy to .env and fill in.

# ─────────────────────────────────────────────────────────────
# LLM Providers (agent backend)
# ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────────
# Supabase (agent backend — server-side only)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ─────────────────────────────────────────────────────────────
# Agent API server config
# ─────────────────────────────────────────────────────────────
CAG_API_HOST=0.0.0.0
CAG_API_PORT=8000
CAG_API_CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Chat agent backend (Next.js)
# ─────────────────────────────────────────────────────────────
AGENT_API_URL=http://localhost:8000
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# WhatsApp Cloud API (pywa) — fill after Meta app setup
# ─────────────────────────────────────────────────────────────
WA_PHONE_ID=
WA_TOKEN=
WA_BUSINESS_ACCOUNT_ID=
WA_APP_ID=
WA_APP_SECRET=
WA_VERIFY_TOKEN=
WA_CALLBACK_URL=
WA_WEBHOOK_ENDPOINT=/whatsapp/webhook

# ─────────────────────────────────────────────────────────────
# Analytics (optional — booking events are fired automatically)
# ─────────────────────────────────────────────────────────────
