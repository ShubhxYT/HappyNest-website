# HappyNest — Blanc Belle: Environment Variables
# Copy to .env.local and fill in.

# ─────────────────────────────────────────────────────────────
# Chat agent backend
# Server-side only (used by the Next.js API route /api/chat/stream).
# Never prefix with NEXT_PUBLIC_ — keep it off the browser.
# ─────────────────────────────────────────────────────────────
AGENT_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# Chat agent backend (client-side — used by leadCapture.ts)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# Analytics (optional — booking events are fired automatically)
# Connect Google Tag Manager or GA4 to receive events:
#   booking_section_viewed, booking_form_started, booking_form_submitted,
#   booking_whatsapp_launched, booking_lead_saved, booking_lead_failed,
#   chat_widget_opened, chat_message_sent, chat_message_received,
#   chat_stream_error
# ─────────────────────────────────────────────────────────────